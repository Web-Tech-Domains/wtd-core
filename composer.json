{
  "name": "webtechdomains/wtd-core",
  "description": "Modern, lightweight, modular PHP framework core by Web Tech Domains.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "autoload": {
    "psr-4": {
      "WTD\\": "system/",
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
    "core"
  ],
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --configuration=phpstan.neon",
    "cs:fix": "php-cs-fixer fix"
  }
}
