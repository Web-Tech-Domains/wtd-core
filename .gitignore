# Composer
/vendor/
composer.lock

# Node / frontend
/node_modules/
# Keep Vite production assets committed because shared PHP hosting may not run npm builds.
!/public/build/
!/public/build/**
/public/hot
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example

# Local databases
/database/*.sqlite
/database/*.sqlite-*

# Logs
/storage/logs/*
!/storage/logs/.gitignore

# Framework runtime state
/storage/framework/*
!/storage/framework/.gitignore

# Cache
/storage/cache/*
!/storage/cache/.gitignore

# Sessions
/storage/sessions/*
!/storage/sessions/.gitignore

# Uploads
/storage/uploads/*
!/storage/uploads/.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo
*.bak

# OS
.DS_Store
Thumbs.db
desktop.ini

# PHPUnit
.phpunit.result.cache
/tests/tmp/

# Coverage
coverage/
/build/
.php-cs-fixer.cache

# Tool caches
/.phpstan.cache/
/.rector.cache/
/.cache/
.gitmessage
