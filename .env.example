APP_NAME="WTD Core"
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:change-this-to-a-strong-random-application-key
APP_URL=http://localhost

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
WTD_AUTO_MIGRATE=true

CACHE_STORE=file
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
MAIL_MAILER=smtp

AWS_URL=https://s3.example.test
AWS_BUCKET=
AWS_DEFAULT_REGION=us-east-1
R2_URL=https://r2.example.test
R2_BUCKET=
R2_ACCOUNT_ID=
AZURE_STORAGE_URL=https://azure.example.test
AZURE_STORAGE_CONTAINER=
GCS_URL=https://gcs.example.test
GCS_BUCKET=
FTP_URL=ftp://files.example.test
FTP_HOST=
FTP_USERNAME=
SFTP_URL=sftp://files.example.test
SFTP_HOST=
SFTP_USERNAME=

AUTH_JWT_SECRET=change-this-to-a-strong-jwt-secret

WTD_DEBUG_TOOLBAR=true
WTD_API_DOCS=true

VITE_DEV_SERVER=http://127.0.0.1:5173
